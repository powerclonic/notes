# Copy this file to .env and fill in your values
# Never commit the .env file

# OpenAI API Key (required)
OPENAI_API_KEY=sk-...

# Backend port (optional, defaults to 3001)
PORT=3001

# JWT secret – use a long random string in production (required for auth security)
JWT_SECRET=change-me-to-a-long-random-secret

# Path for the users database JSON file (optional, defaults to ./data/users.json)
# USERS_DB_PATH=/var/data/users.json
